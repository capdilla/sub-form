{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2018",
    "noEmit": true,
    "sourceMap": false,
    "declarationMap": false,
    "types": ["@types/react", "@types/react-dom"]
  },
  "include": ["src/lib"],
  "exclude": [
    "*/**/__test__",
    "__tests__",
    "build",
    "*/**/*.stories.tsx",
    "*/**/*.test.tsx"
  ]
}
