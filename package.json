{
  "name": "sub-formx",
  "version": "1.0.0",
  "files": [
    "build"
  ],
  "sideEffects": false,
  "main": "./build/index.cjs",
  "module": "./build/index.js",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js",
      "require": "./build/index.cjs"
    }
  },
  "scripts": {
    "dev": "bun --bun vite",
    "build": "rm -rf build 2> /dev/null && vite build --config vite.lib.config.ts && dts-bundle-generator --no-check --project tsconfig.build.json -o build/index.d.ts src/lib/index.ts && bun run scripts/post-build.js",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "bun test",
    "test:coverage:ci": "bun run scripts/check-coverage.js"
  },
  "peerDependencies": {
    "react": "^18.2.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@happy-dom/global-registrator": "^13.1.4",
    "@testing-library/react": "^14.1.2",
    "@types/bun": "^1.0.6",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react-swc": "^3.3.2",
    "dts-bundle-generator": "^9.5.1",
    "eslint": "^8.45.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.0.2",
    "vite": "^4.4.5"
  }
}
